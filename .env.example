# API
PORT=3000
DATABASE_URL=mysql://api_user:api_password@mysql:3306/api_collection
OILPRICE_API_URL=https://api.istero.com/resource/v2/oilprice
# Required: upstream bearer token from api.istero.com
OILPRICE_API_TOKEN=replace_with_your_istero_token

# MySQL (used by docker-compose local db)
MYSQL_ROOT_PASSWORD=root_password
MYSQL_DATABASE=api_collection
MYSQL_USER=api_user
MYSQL_PASSWORD=api_password
MYSQL_PORT=3306
